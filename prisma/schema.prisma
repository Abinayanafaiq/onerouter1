generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  name           String?
  role           String          @default("USER")
  whatsapp       String?
  rateLimit      Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  apiKeys        ApiKey[]
  orders         Order[]
  wallet         Wallet?
  usageLogs      UsageLog[]
  apiRequestLogs ApiRequestLog[]
}

model AIModel {
  id                    String   @id @default(cuid())
  modelId               String   @unique
  masterId              String
  name                  String
  provider              String   @default("prokuy")
  description           String?
  contextWindow         String?
  inputPricePerMillion  Decimal  @db.Decimal(12, 4)
  outputPricePerMillion Decimal  @db.Decimal(12, 4)
  supportsText          Boolean  @default(true)
  supportsImages        Boolean  @default(false)
  supportsStreaming     Boolean  @default(true)
  enabled               Boolean  @default(true)
  maintenanceMode       Boolean  @default(false)
  sort                  Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  usageLogs             UsageLog[]
}

model Wallet {
  id           String             @id @default(cuid())
  userId       String             @unique
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Decimal            @db.Decimal(14, 4) @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  transactions WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        String
  amount      Decimal  @db.Decimal(14, 4)
  description String?
  createdAt   DateTime @default(now())

  @@index([walletId, createdAt])
}

model Package {
  id           String   @id @default(cuid())
  name         String
  description  String?
  tokenQuota   BigInt
  price        Int
  durationDays Int      @default(14)
  isActive     Boolean  @default(true)
  sort         Int      @default(0)
  stock        Int      @default(0)
  orders       Order[]
  createdAt    DateTime @default(now())
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId       String
  package         Package  @relation(fields: [packageId], references: [id])
  amount          Int
  whatsapp        String?
  paymentMethod   String   @default("MANUAL")
  cryptoChain     String?
  cryptoAmount    String?
  btcpayInvoiceId String?
  nowpaymentsInvoiceId String?
  nowpaymentsPaymentId  String?
  nowpaymentsPayCurrency String?
  cryptoExpectedAmount  String?
  pakasirMethod        String?
  pakasirPaymentNumber String?
  pakasirExpiredAt     DateTime?
  status          String   @default("PENDING")
  paymentProof    String?
  adminNote       String?
  activatedAt     DateTime?
  expiresAt       DateTime?
  apiKeyId        String?
  apiKey          ApiKey?   @relation(fields: [apiKeyId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ApiKey {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Full plaintext key is only stored for legacy order-generated keys. New
  // user-generated keys leave this null and store only the hash.
  key            String?    @unique
  keyHash        String     @unique
  prefix         String?
  last4          String?
  masterApiKey   String?
  name           String?
  label          String?
  // Permissions / limits
  enabled        Boolean    @default(true)
  ipWhitelist    String[]   @default([])
  rateLimit      Int?
  allowedModels  String[]   @default([])
  tokenQuota     BigInt     @default(0)
  tokenUsed      BigInt     @default(0)
  requestCount   Int        @default(0)
  requestToday   Int        @default(0)
  lastRequestAt  DateTime?
  lastUsedAt     DateTime?
  lastResetDay   DateTime   @default(now())
  expiresAt      DateTime?
  isActive       Boolean    @default(true)
  usageLogs      UsageLog[]
  apiRequestLogs ApiRequestLog[]
  orders         Order[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now()) @updatedAt

  @@index([userId])
  @@index([enabled])
}

model UsageLog {
  id                String   @id @default(cuid())
  apiKeyId          String
  apiKey            ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  modelId           String?
  aiModel           AIModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)
  model             String
  provider          String   @default("prokuy")
  status            String   @default("success")
  promptTokens      Int
  completionTokens  Int
  totalTokens       Int
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  inputCost         Decimal  @db.Decimal(12, 6) @default(0)
  outputCost        Decimal  @db.Decimal(12, 6) @default(0)
  totalCost         Decimal  @db.Decimal(12, 6) @default(0)
  remainingBalance  Decimal  @db.Decimal(14, 4) @default(0)
  createdAt         DateTime @default(now())

  @@index([apiKeyId, createdAt])
  @@index([userId, createdAt])
  @@index([modelId, createdAt])
  @@index([userId, status, createdAt])
}

model ApiRequestLog {
  id               String   @id @default(cuid())
  apiKeyId         String
  apiKey           ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider         String   @default("unknown")
  model            String
  endpoint         String
  method           String   @default("POST")
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  totalTokens      Int      @default(0)
  inputCost        Decimal  @db.Decimal(12, 6) @default(0)
  outputCost       Decimal  @db.Decimal(12, 6) @default(0)
  totalCost        Decimal  @db.Decimal(12, 6) @default(0)
  remainingBalance Decimal  @db.Decimal(14, 4) @default(0)
  responseTime     Int      @default(0)
  statusCode       Int      @default(200)
  success          Boolean  @default(true)
  clientIp         String?
  userAgent        String?
  createdAt        DateTime @default(now())

  @@index([apiKeyId, createdAt])
  @@index([userId, createdAt])
  @@index([model, createdAt])
  @@index([provider, createdAt])
  @@index([createdAt])
  @@index([success, createdAt])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model MasterApiKey {
  id             String    @id @default(cuid())
  label          String
  cipher         String
  prefix         String?
  last4          String?
  priority       Int       @default(0)
  enabled        Boolean   @default(true)
  lastUsedAt     DateTime?
  lastErrorAt    DateTime?
  lastErrorStatus Int?
  lastErrorMsg   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([enabled, priority])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  target      String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
}
